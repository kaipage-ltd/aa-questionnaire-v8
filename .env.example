# V8 production plumbing. Copy values into Vercel environment variables.

# Required for /api/v8/submit and /api/v8/reveal.
# Generate with: openssl rand -base64 48
JWT_SECRET=replace-with-strong-random-secret

# Public base URL used to build reveal/PDF links in emails.
PUBLIC_SITE_URL=https://your-vercel-domain.vercel.app

# Required in Vercel production before deploying bot-protection enforcement.
# Create a Cloudflare Turnstile Managed widget for the live questionnaire host.
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
TURNSTILE_ALLOWED_HOSTNAMES=aa-questionnaire-v8.vercel.app

# Optional Brevo delivery.
# If BREVO_API_KEY is absent, submit still returns tokenized reveal/pdf URLs but emailSent=false.
# If BREVO_API_KEY is present, the API creates/updates the contact and stores these attributes:
# AA_REVEAL_URL, AA_PDF_URL, AA_PROFILE_NAME, AA_PROFILE_KEY, AA_PROFILE_SCORE,
# AA_PROFILE_HURDLE, AA_SUBMITTED_AT, FIRSTNAME.
BREVO_API_KEY=

# Optional until the Brevo list exists. When present, synced contacts are added to this list.
BREVO_LIST_ID=

# Required for actual email sending. Can be left blank while DNS/sender identity is pending.
BREVO_TEMPLATE_ID=
BREVO_SENDER_EMAIL=
BREVO_SENDER_NAME=Atelier & Avenue
BREVO_REPLY_TO_EMAIL=

# Optional internal notification copy.
INTERNAL_NOTIFY_EMAIL=
